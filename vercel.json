{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/inngest/index.ts": {
      "maxDuration": 60
    },
    "api/debug/test-provision.ts": {
      "maxDuration": 30
    }
  },
  "ignoreCommand": "bash ./tools/vercel-ignore-paperclip-only.sh"
}

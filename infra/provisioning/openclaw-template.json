{
  "_comment": "OpenClaw configuration template for fresh PixelPort tenants. Matches buildOpenClawConfig() in api/inngest/functions/provision-tenant.ts; the workspace contract itself is generated separately into workspace-main plus pixelport/.",
  "_note": "Gemini-backed web search is emitted only when GEMINI_API_KEY exists in the deploy environment.",
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "{{GATEWAY_TOKEN}}"
    },
    "bind": "lan",
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "acp": {
    "_comment": "Disable ACP dispatch for fresh-tenant canaries unless a release-specific validation pass explicitly approves enabling it.",
    "dispatch": {
      "enabled": false
    }
  },
  "hooks": {
    "_comment": "Runtime uses buildBootstrapHooksConfig() to derive a separate hook token from the gateway token."
  },
  "tools": {
    "sessions": {
      "visibility": "all"
    },
    "agentToAgent": {
      "enabled": true
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "litellm/gpt-5.4",
        "fallbacks": [
          "litellm/gemini-2.5-flash",
          "litellm/gpt-4o-mini"
        ]
      },
      "subagents": {
        "maxSpawnDepth": 2,
        "maxChildrenPerAgent": 5
      }
    },
    "list": [
      {
        "id": "main",
        "name": "{{AGENT_NAME}}",
        "workspace": "/home/node/.openclaw/workspace-main",
        "model": "litellm/gpt-5.4",
        "subagents": {
          "allowAgents": [
            "*"
          ]
        },
        "tools": {
          "profile": "full",
          "deny": [
            "browser"
          ]
        }
      }
    ]
  },
  "models": {
    "mode": "merge",
    "providers": {
      "litellm": {
        "baseUrl": "{{LITELLM_URL}}/v1",
        "apiKey": "${OPENAI_API_KEY}",
        "api": "openai-responses",
        "authHeader": true,
        "models": [
          {
            "id": "gpt-5.4",
            "name": "GPT 5.4",
            "api": "openai-responses",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 128000,
            "maxTokens": 32000
          },
          {
            "id": "gpt-4o-mini",
            "name": "GPT 4o Mini",
            "api": "openai-responses",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 128000,
            "maxTokens": 16384
          },
          {
            "id": "gemini-2.5-flash",
            "name": "Gemini 2.5 Flash",
            "api": "openai-responses",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 1048576,
            "maxTokens": 8192
          }
        ]
      }
    }
  }
}
